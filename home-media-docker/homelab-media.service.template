[Unit]
Description=Homelab Media Stack
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
Restart=on-failure
RestartSec=10s
WorkingDirectory=__HOMELAB_ROOT__
ExecStart=__HOMELAB_ROOT__/launch.bash home-media-docker start
ExecStop=__HOMELAB_ROOT__/launch.bash home-media-docker stop

[Install]
WantedBy=multi-user.target
